---
import '../styles/global.css';

const { title, description = "My personal portfolio and blog" } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <header class="site-header">
    <!-- 🔧 Replace "Your Name" with your name -->
    <a href="/" class="site-name">Your Name</a>
    <nav>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>home</a>
      <a href="/articles" class={currentPath.startsWith('/articles') ? 'active' : ''}>articles</a>
      <a href="/projects" class={currentPath === '/projects' ? 'active' : ''}>projects</a>
      <!-- 🔧 Replace with your GitHub URL -->
      <a href="https://github.com/yourusername" target="_blank" rel="noopener">github</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <!-- 🔧 Update footer text as you like -->
    built with <a href="https://astro.build">astro</a> · hosted on <a href="https://pages.github.com">github pages</a>
  </footer>
</body>
</html>
